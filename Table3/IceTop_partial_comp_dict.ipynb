    "# [CHANGED] ── Crystal Ball / DPL models, sigma-weighted fit, and model dispatch ──────\n",
    "#\n",
    "# Replaces direct weighted_quantiles() calls.  The workflow is:\n",
    "#   1. Build a weighted log10(E/PeV) histogram from the event array.\n",
    "#   2. Compute per-bin statistical errors: sigma_i = sqrt(sum w_j^2)/(total_w*dbin).\n",
    "#   3. Pick the model for this tier:\n",
    "#        Tier 1 (full-sky)  or  1a/1b (split-sky)  ->  Crystal Ball (CB)\n",
    "#        all other tiers                           ->  Gaussian + broken\n",
    "#                                                        power law (DPL),\n",
    "#                                                        using the optimized\n",
    "#                                                        per-tier k_peak\n",
    "#   4. Fit with sigma-weighted curve_fit (absolute_sigma=True).\n",
    "#   5. Invert the fit CDF over the extended range to get quantiles in eV.\n",
    "#\n",
    "# Histogram binning: 39 uniform bins in log10(E/PeV), -1.0 to +1.925, dbin=0.075.\n",
    "# Integration range for CDF: extended range [-2.0, +2.5] in log10(E/PeV).\n",
    "\n",
    "# ── Histogram / fit constants ────────────────────────────────────────────────\n",
    "HIST_BIN_EDGES  = np.linspace(-1.0, 1.925, 40)           # [CHANGED]\n",
    "HIST_BIN_WIDTH  = HIST_BIN_EDGES[1] - HIST_BIN_EDGES[0]  # [CHANGED]\n",
    "HIST_BIN_CTRS   = 0.5*(HIST_BIN_EDGES[:-1]+HIST_BIN_EDGES[1:])  # [CHANGED]\n",
    "X_EXT_LO, X_EXT_HI = -2.0, 2.5                           # [CHANGED]\n",
    "X_KNEE_PEV = 3.0                                           # [CHANGED]\n",
    "\n",
    "CB_BOUNDS = (                                               # [CHANGED]\n",
    "    [0.0, -2.0, 0.05,  0.1,  1.1],   # A, mu, sigma, alpha, n\n",
    "    [5.0,  2.5, 2.00, 10.0, 50.0],\n",
    ")                                                           # [CHANGED]\n",
    "\n",
    "DPL_BOUNDS = (                                               # [CHANGED]\n",
    "    [0.0, -1.5,  0.05,  0.0,  0.0,  0.05],\n",
    "    [5.0,  2.2,  2.00, 20.0, 20.0,  3.00],\n",
    ")                                                           # [CHANGED]\n",
    "\n",
    "# ── Model assignment per tier ──────────────────────────────────────────────\n",
    "#\n",
    "# Tier 1 (full-sky) and 1a/1b (split-sky) use the Crystal Ball (CB); this is\n",
    "# the lowest-energy tier where the asymmetric Gaussian-like core with a\n",
    "# single power-law tail fits better than the DPL's logistic blend.        # [CHANGED]\n",
    "MODEL_FULL = {                                               # [CHANGED]\n",
    "    'Tier 1': 'CB', 'Tier 2': 'DPL', 'Tier 3': 'DPL', 'Tier 4': 'DPL',\n",
    "}                                                             # [CHANGED]\n",
    "K_PEAK_FULL = 10.0   # fixed k_peak for DPL fits on the (unsplit) full-sky # [CHANGED]\n",
    "\n",
    "# Per-tier optimal k_peak (sigma-weighted reduced-chi2 profile scan,       # [CHANGED]\n",
    "# split-sky 8-tier binning).  Only used for tiers fit with DPL; the        # [CHANGED]\n",
    "# 1a/1b entries are kept for reference but are not used since those        # [CHANGED]\n",
    "# tiers are fit with CB instead (CB has no k_peak parameter).              # [CHANGED]\n",
    "K_PEAK_SPLIT = {                                             # [CHANGED]\n",
    "    ('Tier 1', 'lo'):  7.0,   # 1a  -- unused (CB fit instead)\n",
    "    ('Tier 1', 'hi'):  5.4,   # 1b  -- unused (CB fit instead)\n",
    "    ('Tier 2', 'lo'):  7.8,   # 2a\n",
    "    ('Tier 2', 'hi'):  5.3,   # 2b\n",
    "    ('Tier 3', 'lo'):  9.6,   # 3a\n",
    "    ('Tier 3', 'hi'):  7.1,   # 3b\n",
    "    ('Tier 4', 'lo'): 10.9,   # 4a\n",
    "    ('Tier 4', 'hi'): 22.1,   # 4b\n",
    "}                                                             # [CHANGED]\n",
    "\n",
    "def get_model_args(tier, zkey=None):                         # [CHANGED]\n",
    "    \"\"\"Return (model_name, k_peak) for a given tier.\n",
    "\n",
    "    zkey=None     -> full-sky (4 tiers, no a/b split)\n",
    "    zkey='lo'/'hi'-> split-sky (8 tiers: 1a,1b,2a,2b,3a,3b,4a,4b)\n",
    "\n",
    "    k_peak is None when model_name == 'CB' (not used by that model).\n",
    "    \"\"\"\n",
    "    if zkey is None:\n",
    "        model_name = MODEL_FULL[tier]\n",
    "        return model_name, (None if model_name == 'CB' else K_PEAK_FULL)\n",
    "    else:\n",
    "        model_name = 'CB' if tier == 'Tier 1' else 'DPL'\n",
    "        return model_name, (None if model_name == 'CB' else K_PEAK_SPLIT[(tier, zkey)])\n",
    "\n",
    "# ── Models ────────────────────────────────────────────────────────────────\n",
    "def crystal_ball(x, A, mu, sigma, alpha, n):                 # [CHANGED]\n",
    "    \"\"\"Gaussian core + power-law tail.  C1-continuous at t=(x-mu)/sigma=alpha.\"\"\"\n",
    "    t = (x - mu) / sigma\n",
    "    C = (n / alpha) ** n * np.exp(-0.5 * alpha ** 2)\n",
    "    return np.where(t <= alpha, A * np.exp(-0.5 * t ** 2),\n",
    "                     A * C / (n / alpha - alpha + t) ** n)\n",
    "\n",
    "def dpl_model(x, A, mu, sigma, gamma1, gamma2, delta_knee,   # [CHANGED]\n",
    "              k_peak=20.0, k_knee=5.0):\n",
    "    \"\"\"Smoothed Gaussian rise / double power-law decay with spectral knee.\"\"\"\n",
    "    x_knee = mu + delta_knee\n",
    "    x      = np.asarray(x, dtype=float)\n",
    "    w_peak = 1.0 / (1.0 + np.exp(-k_peak * (x - mu)))\n",
    "    gauss  = A * np.exp(-0.5 * ((x - mu) / sigma) ** 2)\n",
    "    pwlaw1 = A * np.exp(-gamma1 * (x - mu))\n",
    "    pwlaw2 = A * np.exp(-gamma1 * delta_knee - gamma2 * (x - x_knee))\n",
    "    w_knee = 1.0 / (1.0 + np.exp(-k_knee * (x - x_knee)))\n",
    "    pwlaw  = (1 - w_knee) * pwlaw1 + w_knee * pwlaw2\n",
    "    return (1 - w_peak) * gauss + w_peak * pwlaw\n",
    "\n",
    "# ── Fit helper ───────────────────────────────────────────────────────────────\n",
    "def fit_quantiles(energy_eV, weights, model_name, k_peak=None,  # [CHANGED]\n",
    "                  quantiles=(0.16, 0.50, 0.84)):\n",
    "    \"\"\"Build histogram -> sigma-weighted CB or DPL fit -> CDF quantiles in eV.\n",
    "\n",
    "    Drop-in replacement for::\n",
    "\n",
    "        weighted_quantiles(energy[cut], weights[cut], quantiles=[.5,.16,.84]) / 1e6\n",
    "\n",
    "    becomes::\n",
    "\n",
    "        model_name, k_peak = get_model_args(tier, zkey)\n",
    "        fit_quantiles(energy[cut], weights[cut], model_name, k_peak) / 1e6\n",
    "\n",
    "    Returns quantiles in ascending order (e.g. Q16, Q50, Q84) in eV.\n",
    "    Falls back to weighted_quantiles on fit failure (too few events,\n",
    "    convergence error, etc.) or if fewer than 7 bins are populated.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    energy_eV  : array of event energies in eV\n",
    "    weights    : per-event weights (Gweights or Hweights)\n",
    "    model_name : 'CB' or 'DPL'\n",
    "    k_peak     : logistic sharpness for the DPL Gaussian-to-power-law\n",
    "                 transition; ignored when model_name == 'CB'\n",
    "    quantiles  : tuple of CDF levels to return\n",
    "    \"\"\"\n",
    "    weights = np.asarray(weights, dtype=float)\n",
    "    if len(energy_eV) == 0 or weights.sum() == 0:\n",
    "        return np.full(len(quantiles), np.nan)\n",
    "\n",
    "    # ── Step 1: weighted histogram and per-bin statistical errors ────────────\n",
    "    log_E   = np.log10(np.asarray(energy_eV, dtype=float) / 1e6)\n",
    "    sum_w,  _ = np.histogram(log_E, bins=HIST_BIN_EDGES, weights=weights)\n",
    "    sum_w2, _ = np.histogram(log_E, bins=HIST_BIN_EDGES, weights=weights**2)\n",
    "    total_w   = weights.sum()\n",
    "    hist_norm = sum_w   / (total_w * HIST_BIN_WIDTH)\n",
    "    hist_err  = np.sqrt(sum_w2) / (total_w * HIST_BIN_WIDTH)  # sigma_i\n",
    "\n",
    "    # ── Step 2: select non-zero bins for fitting ─────────────────────────────\n",
    "    fit_mask = (hist_norm > 0) & (hist_err > 0)\n",
    "    if fit_mask.sum() < 7:\n",
    "        return weighted_quantiles(energy_eV, weights, quantiles=list(quantiles))\n",
    "\n",
    "    xd, yd, ye = (HIST_BIN_CTRS[fit_mask],\n",
    "                  hist_norm[fit_mask],\n",
    "                  hist_err[fit_mask])\n",
    "\n",
    "    peak_bin = np.argmax(hist_norm)\n",
    "    mu_g     = HIST_BIN_CTRS[peak_bin]\n",
    "\n",
    "    # ── Step 3: sigma-weighted curve_fit with the assigned model ─────────────\n",
    "    try:\n",
    "        if model_name == 'CB':                                  # [CHANGED]\n",
    "            p0 = [float(yd.max()), mu_g, 0.45, 1.0, 3.0]\n",
    "            popt, _ = curve_fit(\n",
    "                crystal_ball, xd, yd,\n",
    "                sigma=ye, absolute_sigma=True,\n",
    "                p0=p0, bounds=CB_BOUNDS, maxfev=12000,\n",
    "            )\n",
    "            model_fn = lambda x: crystal_ball(x, *popt)\n",
    "        else:  # 'DPL'                                            # [CHANGED]\n",
    "            dk_g = max(np.log10(X_KNEE_PEV / 10**mu_g), 0.15)\n",
    "            p0   = [float(yd.max()), mu_g, 0.40, 3.0, 5.0, dk_g]\n",
    "\n",
    "            def _fixed(x, A, mu, s, g1, g2, dk):\n",
    "                return dpl_model(x, A, mu, s, g1, g2, dk, k_peak=k_peak)\n",
    "\n",
    "            popt, _ = curve_fit(\n",
    "                _fixed, xd, yd,\n",
    "                sigma=ye, absolute_sigma=True,\n",
    "                p0=p0, bounds=DPL_BOUNDS, maxfev=12000,\n",
    "            )\n",
    "            model_fn = lambda x: _fixed(x, *popt)\n",
    "    except (RuntimeError, ValueError):\n",
    "        return weighted_quantiles(energy_eV, weights, quantiles=list(quantiles))\n",
    "\n",
    "    # ── Step 4: CDF inversion over extended range ─────────────────────────────\n",
    "    xs  = np.linspace(X_EXT_LO, X_EXT_HI, 4000)\n",
    "    ys  = model_fn(xs)\n",
    "    cdf = cumulative_trapezoid(ys, xs, initial=0.0)\n",
    "    if cdf[-1] == 0:\n",
    "        return np.full(len(quantiles), np.nan)\n",
    "    cdf /= cdf[-1]\n",
    "\n",
    "    out = []\n",
    "    for q in quantiles:\n",
    "        idx  = int(np.clip(np.searchsorted(cdf, q), 1, len(xs)-1))\n",
    "        frac = (q - cdf[idx-1]) / (cdf[idx] - cdf[idx-1])\n",
    "        out.append(10**(xs[idx-1] + frac*(xs[idx]-xs[idx-1])) * 1e6)  # -> eV\n",
    "    return np.array(out)\n"
